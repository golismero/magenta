{
    "$schema": "https://json-schema.org/draft/2019-09/schema",
    "type": "object",
    "properties": {
        "bandit": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^B[0-9][0-9][0-9]$"}},
        "code": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "properties": {
                    "file": {"type": "string"},
                    "line": {"type": "integer"},
                    "trace": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "file": {"type": "string"},
                                "language": {"type": "string"},
                                "source": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "line": {"type": "integer"},
                                            "text": {"type": "string"}
                                        },
                                        "required": ["text"]
                                    }
                                },
                                "highlight": {
                                    "type": "object",
                                    "properties": {
                                        "line": {"type": "integer"},
                                        "start": {"type": "integer"},
                                        "end": {"type": "integer"}
                                    }
                                }
                            },
                            "required": ["file", "source"]
                        }
                    }
                },
                "required": ["file", "line"]
            }
        }
    },
    "required": ["code"]
}