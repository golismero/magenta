{
    "$schema": "https://json-schema.org/draft/2019-09/schema",
    "type": "object",
    "properties": {
        "credentials": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "properties": {
                    "host": {"type": "string"},
                    "port": {"type": "string"},
                    "service": {"type": "string"},
                    "login": {"type": "string"},
                    "password": {"type": "string"}
                },
                "required": ["host", "port", "service", "login", "password"]
            }
        }
    },
    "required": ["credentials"]
}